<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Root checking state -->
        <LinearLayout
            android:id="@+id/layout_root_checking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="64dp"
            android:visibility="gone">
            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking root access…"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Root denied state -->
        <LinearLayout
            android:id="@+id/layout_root_denied"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Root access required"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This app needs root (su) to modify CPU governor settings. Grant root access in your root manager app (e.g. Magisk), then try again."
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:paddingHorizontal="16dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry_root"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry"
                android:layout_marginTop="24dp" />
        </LinearLayout>

        <!-- Main content -->
        <LinearLayout
            android:id="@+id/layout_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU Governor"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lenovo Tab M10 HD · TB-X606F"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_active_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active: detecting…"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:layout_marginBottom="20dp" />

            <!-- Profile selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POWER PROFILE"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="8dp" />

            <!-- Profile cards 2x2 grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_battery_saver"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔋" android:textSize="24sp" android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Battery saver" android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="powersave" android:textSize="11sp" android:textColor="@color/text_tertiary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_eco"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌿" android:textSize="24sp" android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Eco" android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="conservative" android:textSize="11sp" android:textColor="@color/text_tertiary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_balanced"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚖️" android:textSize="24sp" android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Balanced" android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="schedutil" android:textSize="11sp" android:textColor="@color/text_tertiary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_performance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚡" android:textSize="24sp" android:layout_marginBottom="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Performance" android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="performance" android:textSize="11sp" android:textColor="@color/text_tertiary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Selected profile summary -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tv_profile_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp"
                        tools:text="Scheduler-driven scaling. Recommended for everyday use." />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Governor" android:textSize="11sp" android:textColor="@color/text_tertiary"/>
                            <TextView android:id="@+id/tv_selected_governor" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" tools:text="schedutil"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Max freq" android:textSize="11sp" android:textColor="@color/text_tertiary"/>
                            <TextView android:id="@+id/tv_selected_max_freq" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" tools:text="1690 MHz"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Est. drain" android:textSize="11sp" android:textColor="@color/text_tertiary"/>
                            <TextView android:id="@+id/tv_selected_drain" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" tools:text="16–24%/hr"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Apply button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_apply"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Apply profile"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"
                app:cornerRadius="12dp" />

            <!-- Core monitor section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CORE MONITOR"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMP" android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:id="@+id/tv_cpu_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="–°C"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/temp_normal"
                    tools:text="42°C" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cores"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    tools:listitem="@layout/item_core"
                    tools:itemCount="8" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updates every 2 seconds. Persists across reboots."
                android:textSize="11sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
